---
import { Image } from 'astro:assets';
import { PRODUCT_LIST } from '../../data/products';
import { formatPrice } from '../../data/products';
import SectionContainer from '../SectionContainer.astro';

const products = PRODUCT_LIST;
---

<section class="products" id="products" aria-labelledby="products-title">
  <SectionContainer>
    <div class="section-heading reveal">
      <p class="section-label">Shop Ana’s Estate</p>

      <h2 id="products-title">Our Olive Oil</h2>

      <div class="ornament" aria-hidden="true">◇</div>

      <p>Choose the format that best suits your table, kitchen or foodservice needs.</p>
    </div>

    <div class="product-grid reveal-group">
      {
        products.map((product) => (
          <article class="product">
            <Image
              src={product.image}
              alt={product.alt}
              loading="lazy"
              widths={[320, 480, 640]}
              sizes="(max-width: 680px) 100vw, 50vw"
            />
            <div>
              <p class="product-format">{product.format}</p>
              <h3>{product.title}</h3>
              <ul>
                <li>Koroneiki Monovarietal</li>
                <li>Early Harvest</li>
                <li>Cold Extracted</li>
                <li>PDO Kalamata</li>
              </ul>
              <div class="price">{formatPrice(product.priceCents)}</div>
              <a class="btn" href={`/checkout?sku=${product.sku}`}>
                Buy Now
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </SectionContainer>
</section>
